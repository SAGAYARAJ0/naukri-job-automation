{
  "buildCommand": "pip install --upgrade pip && pip install -r requirements.txt",
  "devCommand": "python app.py",
  "env": {
    "PYTHONUNBUFFERED": "1",
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "runtime": "python3.11",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "wsgi.py"
    }
  ]
}
